## To load environment variables from this .env file paste the following line in
## your .bashrc (or .bash_profile, .zshrc, etc.)
## Don't forget to remove the leading # signs and your own path to the .env file
#
# JUKEBOX_ENV_PATH="/your/path/jukebox/.env"
# if [ -f $JUKEBOX_ENV_PATH ]; then
#     export $(grep -v '^#' $JUKEBOX_ENV_PATH | xargs)
# fi

## Sonos speaker selection — pick one, or omit both to use auto-discovery
# JUKEBOX_SONOS_HOST="XXX.XXX.XXX.XXX"  # IP address or hostname
# JUKEBOX_SONOS_NAME="Living Room"      # speaker name (case-sensitive)

## Path of the library.json file, optional
# JUKEBOX_LIBRARY_PATH="~/.jukebox/library.json"
